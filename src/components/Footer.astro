---
---

<footer class="bg-primary overflow-hidden relative">
    <!-- Top gradient line -->
    <div class="h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>

    <!-- Big CTA -->
    <div class="max-w-6xl mx-auto px-6 pt-16 md:pt-32 pb-12 md:pb-28">
        <div data-reveal="fade">
            <span class="text-[10px] uppercase tracking-[0.4em] text-white/30 font-semibold block mb-4 md:mb-6">Ready to Move?</span>
            <h2 class="text-4xl md:text-7xl lg:text-[5.5rem] leading-[0.9] tracking-tight text-white">
                Where Will Your<br />
                <span class="serif-italic text-accent-orange">Journey</span> Take You?
            </h2>
        </div>
    </div>

    <!-- Main footer content -->
    <div class="max-w-6xl mx-auto px-6 pb-12 md:pb-16">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-12 lg:gap-12">
            <!-- Left — brand + social -->
            <div class="lg:col-span-5 space-y-6 md:space-y-8">
                <div>
                    <span class="text-2xl font-bold text-white tracking-tight" style="font-family: var(--font-heading);">MotivPro</span>
                </div>
                <p class="text-white/40 text-sm font-light leading-relaxed max-w-xs">
                    Transformative global experiences bridging the gap between Ghanaian ambition and international opportunity.
                </p>
                <div class="flex gap-4">
                    <a href="#" class="group flex items-center gap-2 text-white/40 text-xs uppercase tracking-widest hover:text-white transition-colors duration-300">
                        <span class="w-8 h-8 rounded-full border border-white/10 flex items-center justify-center group-hover:border-accent-orange group-hover:bg-accent-orange transition-all duration-300">
                            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"></path></svg>
                        </span>
                    </a>
                    <a href="#" class="group flex items-center gap-2 text-white/40 text-xs uppercase tracking-widest hover:text-white transition-colors duration-300">
                        <span class="w-8 h-8 rounded-full border border-white/10 flex items-center justify-center group-hover:border-accent-orange group-hover:bg-accent-orange transition-all duration-300">
                            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073z"></path></svg>
                        </span>
                    </a>
                    <a href="#" class="group flex items-center gap-2 text-white/40 text-xs uppercase tracking-widest hover:text-white transition-colors duration-300">
                        <span class="w-8 h-8 rounded-full border border-white/10 flex items-center justify-center group-hover:border-accent-orange group-hover:bg-accent-orange transition-all duration-300">
                            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"></path></svg>
                        </span>
                    </a>
                </div>
            </div>

            <!-- Middle — links -->
            <div class="lg:col-span-3 lg:col-start-7 space-y-8 md:space-y-10">
                <div class="space-y-4 md:space-y-5">
                    <h4 class="text-[10px] font-bold uppercase tracking-[0.3em] text-white/25">Company</h4>
                    <ul class="space-y-2.5 md:space-y-3">
                        <li><a href="#about" class="group inline-flex items-center gap-2 text-white/50 text-sm font-light hover:text-white transition-colors duration-300">About Us <span class="w-0 h-px bg-accent-orange group-hover:w-4 transition-all duration-300"></span></a></li>
                        <li><a href="#services" class="group inline-flex items-center gap-2 text-white/50 text-sm font-light hover:text-white transition-colors duration-300">Our Mission <span class="w-0 h-px bg-accent-orange group-hover:w-4 transition-all duration-300"></span></a></li>
                        <li><a href="#contact" class="group inline-flex items-center gap-2 text-white/50 text-sm font-light hover:text-white transition-colors duration-300">Careers <span class="w-0 h-px bg-accent-orange group-hover:w-4 transition-all duration-300"></span></a></li>
                    </ul>
                </div>
                <div class="space-y-4 md:space-y-5">
                    <h4 class="text-[10px] font-bold uppercase tracking-[0.3em] text-white/25">Services</h4>
                    <ul class="space-y-2.5 md:space-y-3">
                        <li><a href="#" class="group inline-flex items-center gap-2 text-white/50 text-sm font-light hover:text-white transition-colors duration-300">Study Missions <span class="w-0 h-px bg-accent-orange group-hover:w-4 transition-all duration-300"></span></a></li>
                        <li><a href="/travel-and-tour" class="group inline-flex items-center gap-2 text-white/50 text-sm font-light hover:text-white transition-colors duration-300">Travel & Tour <span class="w-0 h-px bg-accent-orange group-hover:w-4 transition-all duration-300"></span></a></li>
                        <li><a href="#" class="group inline-flex items-center gap-2 text-white/50 text-sm font-light hover:text-white transition-colors duration-300">Consultancy <span class="w-0 h-px bg-accent-orange group-hover:w-4 transition-all duration-300"></span></a></li>
                    </ul>
                </div>
            </div>

            <!-- Right — newsletter -->
            <div class="lg:col-span-4 space-y-5 md:space-y-6">
                <div class="space-y-3 md:space-y-4">
                    <h4 class="text-[10px] font-bold uppercase tracking-[0.3em] text-white/25">Stay Updated</h4>
                    <p class="text-white/40 text-sm font-light">Get insights on global mobility, scholarships, and travel opportunities.</p>
                </div>
                <div class="relative">
                    <input
                        type="email"
                        placeholder="your@email.com"
                        class="w-full bg-transparent border-b border-white/10 pb-3 text-white text-sm font-light placeholder:text-white/25 focus:outline-none focus:border-accent-orange transition-colors duration-300 pr-10"
                    />
                    <button class="absolute right-0 bottom-3 text-white/30 hover:text-accent-orange transition-colors duration-300">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                    </button>
                </div>
                <div class="flex items-center gap-2 text-white/20">
                    <span class="text-[10px]">Accra, Ghana</span>
                    <span class="w-1 h-1 rounded-full bg-white/10"></span>
                    <a href="mailto:info@motivprogroup.com" class="text-[10px] hover:text-white/50 transition-colors">info@motivprogroup.com</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Bottom bar -->
    <div class="max-w-6xl mx-auto px-6 py-6 border-t border-white/5">
        <div class="flex flex-col md:flex-row justify-between items-center gap-4">
            <p class="text-white/20 text-[11px] font-light tracking-wide">
                &copy; 2026 Motiv Pro Group.
            </p>
            <div class="flex gap-6">
                <a href="#" class="text-white/20 text-[11px] font-light hover:text-white/50 transition-colors">Privacy</a>
                <a href="#" class="text-white/20 text-[11px] font-light hover:text-white/50 transition-colors">Terms</a>
            </div>
        </div>
    </div>
</footer>
