---
const services = [
    {
        title: "Bespoke Expeditions",
        description:
            "Curating unique, off-the-beaten-path journeys that connect you with the soul of a destination.",
        image: "/service_study_abroad.png",
        category: "Leisure",
    },
    {
        title: "Corporate Retreats",
        description:
            "Seamless logistical support for professional gatherings in the world's most inspiring locations.",
        image: "/service_corporate_tours.png",
        category: "Business",
    },
    {
        title: "Global Concierge",
        description:
            "Expert visa assistance and travel protocol to ensure your international mobility is effortless.",
        image: "/service_travel_protocol.png",
        category: "Logistics",
    },
];
---

<section class="section-padding bg-background" id="services">
    <div class="max-w-editorial px-6 md:px-12">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 md:gap-12 mb-16 md:mb-32">
            <div class="lg:col-span-8" data-reveal="fade">
                <span class="text-[10px] uppercase tracking-[0.4em] text-text-muted font-semibold block mb-4 md:mb-6">What We Offer</span>
                <h2 class="text-5xl md:text-7xl lg:text-[9rem] leading-[0.85] tracking-tight">
                    Our <span class="serif-italic">Premium</span><br />Services.
                </h2>
            </div>
            <div class="lg:col-span-4 flex items-end" data-reveal="fade">
                <p class="text-base md:text-lg text-primary/60 font-light leading-relaxed max-w-sm">
                    Comprehensive solutions tailored to help you achieve your international aspirations with precision and elegance.
                </p>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-x-8 gap-y-16 md:gap-y-24">
            {
                services.map((service) => (
                    <div class="group" data-reveal="fade">
                        <div class="relative aspect-[4/5] overflow-hidden mb-6 md:mb-10 rounded-sm">
                            <img
                                src={service.image}
                                alt={service.title}
                                class="w-full h-full object-cover transition-transform duration-700 ease-editorial group-hover:scale-110"
                            />
                            <div class="absolute inset-0 bg-gradient-to-t from-primary/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                            <div class="absolute top-6 left-6">
                                <span class="bg-white/95 backdrop-blur-md text-primary px-4 py-2 text-[9px] uppercase tracking-[0.2em] font-bold rounded-full shadow-sm">
                                    {service.category}
                                </span>
                            </div>
                        </div>

                        <h3 class="text-2xl md:text-4xl mb-3 md:mb-4 tracking-tight group-hover:serif-italic transition-all duration-500 ease-editorial">
                            {service.title}
                        </h3>
                        <p class="text-primary/60 font-light leading-relaxed mb-6 md:mb-8 max-w-[90%]">
                            {service.description}
                        </p>

                        <a
                            href="#contact"
                            class="inline-flex items-center gap-4 text-[10px] uppercase tracking-[0.3em] font-bold group/link"
                        >
                            Explore
                            <span class="w-8 h-px bg-primary/20 transition-all duration-500 ease-editorial group-hover/link:w-14 group-hover/link:bg-primary"></span>
                        </a>
                    </div>
                ))
            }
        </div>
    </div>
</section>
