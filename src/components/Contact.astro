---
---

<section class="section-padding bg-background border-t border-accent/20" id="contact">
    <div class="max-w-editorial px-6 md:px-12">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-24">
            <!-- Info -->
            <div class="lg:col-span-5 space-y-10 md:space-y-12">
                <div class="space-y-4 md:space-y-6">
                    <span class="text-[10px] uppercase tracking-[0.4em] text-text-muted font-semibold block" data-reveal="fade">Get in Touch</span>
                    <h2 class="text-4xl md:text-6xl lg:text-7xl leading-[0.9] tracking-tight" data-reveal="fade">
                        Let's Build Your <br /><span class="serif-italic text-accent">Legacy.</span>
                    </h2>
                    <p class="text-base md:text-lg text-text-muted font-light leading-relaxed max-w-sm" data-reveal="fade">
                        Ready to take the next step in your global journey? Connect with our experts for a personalized consultation.
                    </p>
                </div>

                <div class="space-y-6 md:space-y-8" data-reveal="fade">
                    <div class="group">
                        <p class="text-[10px] uppercase tracking-[0.3em] text-accent mb-2">Email</p>
                        <a href="mailto:info@motivprogroup.com" class="text-lg md:text-2xl font-light hover:text-accent-orange transition-colors duration-300">info@motivprogroup.com</a>
                    </div>

                    <div class="group">
                        <p class="text-[10px] uppercase tracking-[0.3em] text-accent mb-2">Location</p>
                        <p class="text-lg md:text-2xl font-light">Accra, Ghana</p>
                    </div>
                </div>
            </div>

            <!-- Form -->
            <div class="lg:col-span-7" data-reveal="fade">
                <form class="space-y-10">
                    <div class="grid md:grid-cols-2 gap-10">
                        <div class="border-b border-accent/30 pb-3 focus-within:border-primary transition-colors duration-300">
                            <label class="text-[10px] uppercase tracking-widest text-accent block mb-3">Name</label>
                            <input
                                type="text"
                                placeholder="Your Name"
                                class="w-full bg-transparent border-none p-0 text-lg font-light focus:ring-0 placeholder:text-accent/30 focus:outline-none"
                            />
                        </div>
                        <div class="border-b border-accent/30 pb-3 focus-within:border-primary transition-colors duration-300">
                            <label class="text-[10px] uppercase tracking-widest text-accent block mb-3">Email</label>
                            <input
                                type="email"
                                placeholder="Your Email"
                                class="w-full bg-transparent border-none p-0 text-lg font-light focus:ring-0 placeholder:text-accent/30 focus:outline-none"
                            />
                        </div>
                    </div>

                    <div class="border-b border-accent/30 pb-3 focus-within:border-primary transition-colors duration-300">
                        <label class="text-[10px] uppercase tracking-widest text-accent block mb-3">Service</label>
                        <select class="w-full bg-transparent border-none p-0 text-lg font-light focus:ring-0 appearance-none focus:outline-none">
                            <option>Educational Missions</option>
                            <option>Corporate Logistics</option>
                            <option>Travel Protocol</option>
                            <option>Consultation</option>
                        </select>
                    </div>

                    <div class="border-b border-accent/30 pb-3 focus-within:border-primary transition-colors duration-300">
                        <label class="text-[10px] uppercase tracking-widest text-accent block mb-3">Message</label>
                        <textarea
                            rows="3"
                            placeholder="How can we help?"
                            class="w-full bg-transparent border-none p-0 text-lg font-light focus:ring-0 resize-none placeholder:text-accent/30 focus:outline-none"
                        ></textarea>
                    </div>

                    <button
                        type="submit"
                        class="btn-editorial w-full py-5 text-sm"
                    >
                        Send Inquiry
                    </button>
                </form>
            </div>
        </div>
    </div>
</section>
