---
import aboutImage from "../assets/isfit-about.jpg";
---

<section class="section-padding bg-background" id="about">
    <div class="max-w-editorial px-6 md:px-12">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-24 items-center">
            <div class="lg:col-span-5 relative" data-reveal="scale">
                <div class="aspect-[3/4] overflow-hidden rounded-sm shadow-2xl shadow-primary/10">
                    <img
                        src={aboutImage.src}
                        alt="The Vision"
                        class="w-full h-full object-cover parallax-img"
                        data-speed="0.05"
                    />
                </div>
                <div class="absolute -bottom-8 -right-8 w-64 h-64 bg-accent/20 rounded-full blur-3xl -z-10"></div>
            </div>

            <div class="lg:col-span-7 space-y-8 lg:space-y-10">
                <div class="space-y-4 lg:space-y-6">
                    <span class="text-[10px] uppercase tracking-[0.4em] text-text-muted font-semibold block" data-reveal="fade">The Art of Travel</span>
                    <h2 class="text-5xl md:text-6xl lg:text-8xl leading-[0.95] tracking-tight" data-reveal="fade">
                        Our <span class="serif-italic">Mission.</span>
                    </h2>
                    <p class="text-base md:text-xl text-primary/70 font-light leading-relaxed max-w-xl" data-reveal="fade">
                        Established in 2023, <span class="text-primary font-medium italic">Motiv Pro Group</span> has been at the forefront of transformative global experiences, bridging the gap between everyday life and extraordinary discovery.
                    </p>
                </div>

                <div class="space-y-8 lg:space-y-10 pt-4">
                    <div class="flex gap-6 md:gap-8" data-reveal="fade">
                        <span class="text-2xl md:text-3xl serif-italic text-accent/60 leading-none">01.</span>
                        <div>
                            <h4 class="text-[10px] uppercase tracking-[0.3em] font-bold mb-3" style="font-family: var(--font-heading);">Curated Destinations</h4>
                            <p class="text-sm text-text-muted font-light leading-relaxed max-w-md">
                                We facilitate access to the world's most evocative locations through specialized travel missions that redefine exploration.
                            </p>
                        </div>
                    </div>

                    <div class="flex gap-6 md:gap-8" data-reveal="fade">
                        <span class="text-2xl md:text-3xl serif-italic text-accent/60 leading-none">02.</span>
                        <div>
                            <h4 class="text-[10px] uppercase tracking-[0.3em] font-bold mb-3" style="font-family: var(--font-heading);">Seamless Journeys</h4>
                            <p class="text-sm text-text-muted font-light leading-relaxed max-w-md">
                                Navigating complex global landscapes with precision and care, ensuring every client's journey is a masterpiece of discovery.
                            </p>
                        </div>
                    </div>
                </div>

                <div class="pt-4" data-reveal="fade">
                    <a href="#contact" class="btn-editorial">Connect with us</a>
                </div>
            </div>
        </div>
    </div>
</section>
