---
const testimonials = [
    {
        quote: "Motiv Pro Group made my study abroad dream a reality. Their team guided me through every step, from university selection to visa approval.",
        author: "Amara Osei",
        role: "Student, UK University",
        avatar: "/avatar_1.png",
    },
    {
        quote: "The corporate tour package was exceptional. Every detail was handled professionally, making our business trip seamless.",
        author: "James Mensah",
        role: "CEO, TechCorp Ghana",
        avatar: "/avatar_2.png",
    },
    {
        quote: "Fast, efficient, and reliable. My visa application was processed quickly with constant updates throughout. Highly recommended!",
        author: "Kofi Asante",
        role: "Business Traveler",
        initials: "KA",
    },
];
---

<section class="py-16 md:py-32 bg-white relative overflow-hidden" id="testimonials">
    <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-accent/30 to-transparent"></div>

    <div class="max-w-6xl mx-auto px-6 relative z-10">
        <div class="text-center mb-12 md:mb-20 space-y-4" data-reveal="fade">
            <span class="text-[10px] uppercase tracking-[0.4em] text-text-muted font-semibold">Success Stories</span>
            <h2 class="text-4xl md:text-7xl leading-[0.9] tracking-tight">
                Institutional <span class="serif-italic text-accent-orange">Trust.</span>
            </h2>
        </div>

        <div class="grid md:grid-cols-3 gap-4 md:gap-6">
            {
                testimonials.map((t) => (
                    <div
                        class="bg-background rounded-2xl p-6 md:p-10 transition-all duration-500 hover:bg-white hover:shadow-2xl hover:shadow-primary/5 border border-transparent hover:border-accent/20 flex flex-col"
                        data-reveal="fade"
                    >
                        <div class="flex items-center gap-1 mb-8 text-accent-orange">
                            {[1, 2, 3, 4, 5].map(() => (
                                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
                                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                </svg>
                            ))}
                        </div>
                        <p class="text-primary font-medium mb-10 leading-relaxed text-[15px] grow">
                            "{t.quote}"
                        </p>
                        <div class="flex items-center gap-4 pt-8 border-t border-accent/15">
                            <div class="relative w-11 h-11">
                                {t.avatar ? (
                                    <img
                                        src={t.avatar}
                                        alt={t.author}
                                        class="w-full h-full rounded-full object-cover"
                                    />
                                ) : (
                                    <div class="w-full h-full rounded-full bg-primary flex items-center justify-center">
                                        <span class="text-white font-bold text-xs">
                                            {t.initials}
                                        </span>
                                    </div>
                                )}
                            </div>
                            <div>
                                <p class="font-bold text-primary text-sm tracking-tight">
                                    {t.author}
                                </p>
                                <p class="text-text-muted text-[11px] uppercase tracking-widest mt-0.5">
                                    {t.role}
                                </p>
                            </div>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>
