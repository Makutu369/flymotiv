---
const travelServices = [
    {
        title: "FIT (Fully Independent Travel)",
        description:
            "For the traveler who wants complete freedom without the hassle of planning. We design highly customized, self-guided itineraries tailored precisely to your personal pace, budget, and interests.",
    },
    {
        title: "Study Missions & Cultural Exchanges",
        description:
            "International education requires precise coordination. We provide specialized travel planning for academic institutions, organizations, and cultural groups with group visa guidance and ground transport.",
    },
    {
        title: "Business Trips",
        description:
            "In corporate travel, efficiency and reliability are everything. We provide streamlined travel management for executives, entrepreneurs, and corporate teams with optimal flight schedules and premium accommodations.",
    },
    {
        title: "Tourism & Leisure",
        description:
            "Your time off should be stress-free. Whether you are looking for a relaxing holiday, a vibrant city break, or an adventurous international getaway, we curate memorable tourism experiences.",
    },
    {
        title: "Group Tours",
        description:
            "Travel is better together. We take the lead on comprehensive group tours for large families, friend groups, and social organizations with group flight rates and coordinated ground transportation.",
    },
];

const whyTravel = [
    {
        title: "Aviation & Industry Expertise",
        description:
            "We know the global travel industry from the inside out, passing our logistical knowledge directly to you.",
        icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>',
    },
    {
        title: "Precision Planning",
        description:
            "We double-check every booking, routing, and requirement so you never have to worry about the details.",
        icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" /></svg>',
    },
    {
        title: "Client-First Support",
        description:
            "Your peace of mind is our top priority. We are with you from your first inquiry until you arrive safely back home.",
        icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>',
    },
];
---

<section class="py-24 md:py-32 bg-grey-bg" id="services">
    <div class="max-w-6xl mx-auto px-6">
        <div class="mb-20 gsap-reveal">
            <span class="section-label">Service Portfolio</span>
            <div class="grid lg:grid-cols-2 gap-12 items-end mt-4">
                <h2
                    class="text-5xl md:text-6xl lg:text-7xl font-bold leading-[0.9] tracking-tight"
                    style="font-family: var(--font-heading);"
                >
                    Motiv Pro <br /><span class="serif-italic text-accent-orange"
                        >Travel & Tour.</span
                    >
                </h2>
                <p
                    class="text-xl md:text-2xl text-text-muted font-light leading-relaxed max-w-xl lg:pb-1"
                >
                    Expert logistical support and seamless planning for leisure,
                    education, or corporate objectives.
                </p>
            </div>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-32">
            {
                travelServices.map((service, index) => (
                    <div
                        class="bg-white p-10 rounded-2xl shadow-lg shadow-black/[0.03] group gsap-reveal border border-transparent hover:border-accent-orange/30 transition-all duration-500 hover:shadow-xl hover:shadow-black/5"
                    >
                        <div class="w-12 h-12 bg-background rounded-xl flex items-center justify-center mb-8 group-hover:bg-accent-orange group-hover:text-white transition-all duration-500">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                            </svg>
                        </div>

                        <h3 class="text-lg font-bold text-primary mb-4 tracking-tight" style="font-family: var(--font-heading);">
                            {service.title}
                        </h3>
                        <p class="text-text-muted text-sm font-light leading-relaxed mb-8">
                            {service.description}
                        </p>

                        <a
                            href="/#contact"
                            class="inline-flex items-center gap-3 text-[10px] font-bold uppercase tracking-[0.2em] text-primary group/link"
                        >
                            Inquire Now
                            <div class="w-7 h-7 bg-background rounded-full flex items-center justify-center group-hover/link:bg-accent-orange group-hover/link:text-white transition-all duration-300">
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                                </svg>
                            </div>
                        </a>
                    </div>
                ))
            }
        </div>

        <!-- Advantage Section -->
        <div
            class="bg-primary rounded-2xl p-12 md:p-16 gsap-reveal text-white relative overflow-hidden"
        >
            <div class="absolute top-0 right-0 w-96 h-96 bg-accent-orange/5 rounded-full blur-[100px]"></div>

            <div class="grid lg:grid-cols-12 gap-12 items-center relative z-10">
                <div class="lg:col-span-4 space-y-6">
                    <span
                        class="text-[10px] font-bold uppercase tracking-[0.3em] text-white/40"
                        >Why Choose Us</span
                    >
                    <h2
                        class="text-3xl md:text-4xl lg:text-5xl font-bold text-white tracking-tight leading-[0.95]"
                        style="font-family: var(--font-heading);"
                    >
                        The Motiv Pro <br /><span class="text-accent-orange"
                            >Advantage.</span
                        >
                    </h2>
                    <p class="text-white/50 font-light leading-relaxed">
                        Precision planning and industry expertise that
                        transforms every journey into a masterpiece.
                    </p>
                </div>

                <div class="lg:col-span-8 grid sm:grid-cols-2 gap-5">
                    {
                        whyTravel.map((reason) => (
                            <div class="bg-white/5 p-8 rounded-2xl border border-white/10 group hover:bg-white transition-all duration-500">
                                <div
                                    class="w-11 h-11 bg-white/10 rounded-xl flex items-center justify-center text-white mb-6 group-hover:bg-accent-orange group-hover:text-white transition-colors duration-500"
                                    set:html={reason.icon}
                                />
                                <h3 class="text-base font-bold text-white group-hover:text-primary mb-3 tracking-tight" style="font-family: var(--font-heading);">
                                    {reason.title}
                                </h3>
                                <p class="text-white/40 group-hover:text-text-muted font-light leading-relaxed text-sm">
                                    {reason.description}
                                </p>
                            </div>
                        ))
                    }
                </div>
            </div>
        </div>
    </div>
</section>
