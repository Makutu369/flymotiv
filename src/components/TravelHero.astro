---
---

<section
    class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden bg-primary"
>
    <!-- Background Image with Overlay -->
    <div class="absolute inset-0 z-0">
        <img
            src="/service_corporate_tours.png"
            alt="Travel background"
            class="w-full h-full object-cover opacity-30 scale-105"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-primary/90 via-primary/70 to-background"></div>
    </div>

    <div class="relative z-10 max-w-6xl mx-auto px-6 text-center text-white">
        <span
            class="inline-block py-1.5 px-4 rounded-full bg-white/5 border border-white/15 text-[11px] font-semibold tracking-widest mb-6 uppercase text-blue-200/80 gsap-reveal"
        >
            Discover The World
        </span>
        <h1
            class="text-5xl md:text-6xl lg:text-7xl font-bold leading-[0.95] tracking-tight mb-8 gsap-reveal"
            style="font-family: var(--font-heading);"
        >
            Motiv Pro <span
                class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-indigo-300"
                >Travel & Tour</span
            >
        </h1>
        <p
            class="text-lg md:text-xl text-slate-300/80 max-w-2xl mx-auto leading-relaxed mb-10 font-light gsap-reveal"
        >
            Expert logistical support and seamless planning for every type of
            journey. Whether for leisure, education, or corporate objectives, we
            ensure your travel is extraordinary.
        </p>
        <div
            class="flex flex-wrap justify-center gap-4 gsap-reveal"
        >
            <a
                href="#services"
                class="inline-flex items-center gap-2 bg-white text-primary px-7 py-3.5 rounded-full font-semibold text-sm transition-all duration-300 hover:shadow-lg hover:shadow-white/20 hover:-translate-y-0.5"
            >
                Explore Services
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
            </a>
            <a
                href="/#contact"
                class="inline-flex items-center gap-2 border border-white/20 bg-white/5 backdrop-blur-sm text-white hover:bg-white hover:text-primary px-7 py-3.5 rounded-full font-medium text-sm transition-all duration-300"
            >
                Book a Consultation
            </a>
        </div>
    </div>
</section>
