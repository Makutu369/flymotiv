---
import paris1 from "../assets/paris/image.png";
import paris2 from "../assets/paris/image copy.png";
import paris3 from "../assets/paris/image copy 2.png";
import paris4 from "../assets/paris/image copy 3.png";
import paris5 from "../assets/paris/image copy 4.png";
---

<section class="py-16 md:py-32 bg-background overflow-hidden" id="paris">
    <!-- Section header -->
    <div class="max-w-6xl mx-auto px-6 mb-12 md:mb-20">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
            <div>
                <span class="text-[10px] uppercase tracking-[0.4em] text-text-muted font-semibold block mb-4" data-reveal="fade">Featured Destination</span>
                <h2 class="text-5xl md:text-7xl lg:text-8xl leading-[0.85] tracking-tight" data-reveal="fade">
                    <span class="serif-italic">Paris.</span>
                </h2>
            </div>
            <div class="max-w-xs" data-reveal="fade">
                <p class="text-sm text-text-muted font-light leading-relaxed">
                    Where history meets ambition. Our curated Paris experiences blend cultural immersion with academic and professional growth.
                </p>
            </div>
        </div>
    </div>

    <!-- Parallax image grid -->
    <div class="max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-6">
            <!-- Large featured image — tall left column -->
            <div class="md:col-span-7 relative overflow-hidden rounded-xl group" data-reveal="clip">
                <div class="aspect-[3/4] md:aspect-[4/5]">
                    <img
                        src={paris1.src}
                        alt="Paris Cityscape"
                        class="w-full h-full object-cover parallax-img"
                        data-speed="0.08"
                    />
                </div>
                <div class="absolute inset-0 bg-gradient-to-t from-primary/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                <div class="absolute bottom-6 left-6 text-white opacity-0 group-hover:opacity-100 transition-all duration-500 translate-y-4 group-hover:translate-y-0">
                    <span class="text-[10px] uppercase tracking-[0.3em] font-semibold block mb-1">City of Light</span>
                    <span class="text-2xl font-bold" style="font-family: var(--font-serif);">Paris, France</span>
                </div>
            </div>

            <!-- Right column — stacked images -->
            <div class="md:col-span-5 flex flex-col gap-4 md:gap-6">
                <div class="relative overflow-hidden rounded-xl group flex-1" data-reveal="clip">
                    <div class="aspect-[4/3]">
                        <img
                            src={paris2.src}
                            alt="Eiffel Tower"
                            class="w-full h-full object-cover parallax-img"
                            data-speed="0.12"
                        />
                    </div>
                    <div class="absolute inset-0 bg-gradient-to-t from-primary/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                </div>

                <div class="relative overflow-hidden rounded-xl group flex-1" data-reveal="clip">
                    <div class="aspect-[4/3]">
                        <img
                            src={paris3.src}
                            alt="Paris Streets"
                            class="w-full h-full object-cover parallax-img"
                            data-speed="0.1"
                        />
                    </div>
                    <div class="absolute inset-0 bg-gradient-to-t from-primary/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                </div>
            </div>
        </div>

        <!-- Bottom row — two equal tall images -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6 mt-4 md:mt-6">
            <div class="relative overflow-hidden rounded-xl group" data-reveal="clip">
                <div class="aspect-[3/4]">
                    <img
                        src={paris4.src}
                        alt="Parisian Architecture"
                        class="w-full h-full object-cover parallax-img"
                        data-speed="0.14"
                    />
                </div>
                <div class="absolute inset-0 bg-gradient-to-t from-primary/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            </div>

            <div class="relative overflow-hidden rounded-xl group" data-reveal="clip">
                <div class="aspect-[3/4]">
                    <img
                        src={paris5.src}
                        alt="Paris by Night"
                        class="w-full h-full object-cover parallax-img"
                        data-speed="0.06"
                    />
                </div>
                <div class="absolute inset-0 bg-gradient-to-t from-primary/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                <div class="absolute bottom-6 right-6 text-right text-white opacity-0 group-hover:opacity-100 transition-all duration-500 translate-y-4 group-hover:translate-y-0">
                    <span class="text-[10px] uppercase tracking-[0.3em] font-semibold block mb-1">Explore</span>
                    <a href="#contact" class="text-sm font-semibold border-b border-white/40 pb-0.5 hover:border-white transition-colors">Plan Your Trip &rarr;</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Bottom text -->
    <div class="max-w-6xl mx-auto px-6 mt-16 md:mt-20">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
            <p class="text-xl md:text-2xl text-primary/70 font-light leading-relaxed" data-reveal="fade">
                From the cobblestone streets of Montmartre to the halls of the Sorbonne — <span class="serif-italic text-primary">every journey begins with a single step.</span>
            </p>
            <div class="flex justify-start md:justify-end" data-reveal="fade">
                <a href="#contact" class="magnetic-btn inline-flex items-center gap-4 text-sm font-semibold uppercase tracking-wider group">
                    <span>Discover All Destinations</span>
                    <span class="w-12 h-px bg-primary group-hover:w-20 transition-all duration-500"></span>
                </a>
            </div>
        </div>
    </div>
</section>
