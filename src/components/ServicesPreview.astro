---

<section class="py-32 bg-white relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="grid md:grid-cols-3 gap-8">
            <div
                class="card p-12 group cursor-pointer border-2 border-slate-100 hover:border-(--primary) transition-all duration-500 rounded-[2.5rem] bg-white"
            >
                <div
                    class="w-16 h-16 bg-(--primary) rounded-2xl flex items-center justify-center mb-10 group-hover:bg-(--accent-orange) transition-colors duration-500"
                >
                    <svg
                        class="w-8 h-8 text-white"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
                        ></path>
                    </svg>
                </div>
                <h3
                    class="text-2xl font-black text-(--primary) mb-6 tracking-tight uppercase"
                >
                    Study Abroad
                </h3>
                <p class="text-(--grey-text) font-bold leading-relaxed">
                    Expert guidance for international education opportunities at
                    top universities worldwide.
                </p>
            </div>

            <div
                class="card p-12 group cursor-pointer border-2 border-slate-100 hover:border-(--primary) transition-all duration-500 rounded-[2.5rem] bg-white"
            >
                <div
                    class="w-16 h-16 bg-(--primary) rounded-2xl flex items-center justify-center mb-10 group-hover:bg-(--accent-orange) transition-colors duration-500"
                >
                    <svg
                        class="w-8 h-8 text-white"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                        ></path>
                    </svg>
                </div>
                <h3
                    class="text-2xl font-black text-(--primary) mb-6 tracking-tight uppercase"
                >
                    Corporate Tours
                </h3>
                <p class="text-(--grey-text) font-bold leading-relaxed">
                    Professional business travel solutions tailored for
                    corporate clients and executives.
                </p>
            </div>

            <div
                class="card p-12 group cursor-pointer border-2 border-slate-100 hover:border-(--primary) transition-all duration-500 rounded-[2.5rem] bg-white"
            >
                <div
                    class="w-16 h-16 bg-(--primary) rounded-2xl flex items-center justify-center mb-10 group-hover:bg-(--accent-orange) transition-colors duration-500"
                >
                    <svg
                        class="w-8 h-8 text-white"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                        ></path>
                    </svg>
                </div>
                <h3
                    class="text-2xl font-black text-(--primary) mb-6 tracking-tight uppercase"
                >
                    Travel Protocol
                </h3>
                <p class="text-(--grey-text) font-bold leading-relaxed">
                    Comprehensive visa and travel documentation services for
                    seamless journeys.
                </p>
            </div>
        </div>
    </div>
</section>
